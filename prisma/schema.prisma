generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  senha     String
  perfil    String
  createdAt DateTime @default(now())
}

model Paciente {
  id              Int      @id @default(autoincrement())
  nome            String
  dataNascimento  DateTime
  observacoes     String?
  createdAt       DateTime @default(now())
}

model Cuidador {
  id        Int    @id @default(autoincrement())
  nome      String
  telefone  String
  email     String @unique
}

model Medicamento {
  id       Int    @id @default(autoincrement())
  nome     String
  dosagem  String
}